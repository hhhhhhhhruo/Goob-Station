<photo:PhotoCardWindow xmlns="https://spacestation14.io"
    xmlns:photo="clr-namespace:Content.Client._Pirate.Photo.UI"
    MouseFilter="Stop" Resizable="False" MinSize="150 150"
    SetSize="430 592">

    <BoxContainer Name="ContentsRoot" Orientation="Vertical">
        <PanelContainer Name="PaperBackground" StyleClasses="PaperDefaultBorder" VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" SeparationOverride="0">
                <PanelContainer Margin="4 4 4 8" StyleClasses="PhotoCardFramePanel" VerticalExpand="True" HorizontalExpand="True">
                    <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" SeparationOverride="0">
                        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" MinHeight="22" Margin="4 4 4 2">
                            <Label Name="PhotoNameLabel" StyleClasses="PhotoCardPrimaryText" HorizontalExpand="True" VerticalAlignment="Center" ClipText="True"/>
                            <PanelContainer StyleClasses="AngleRect" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <TextureButton Name="CloseButton" StyleClasses="windowCloseButton"/>
                            </PanelContainer>
                        </BoxContainer>

                        <TextureRect Name="ImageDisplay" VerticalExpand="True" HorizontalExpand="True" Stretch="Scale" Margin="4 0 4 0"/>

                        <PanelContainer Name="CaptionContainer" HorizontalExpand="True" MinHeight="132" Margin="4 2 4 4">
                            <RichTextLabel Name="CaptionLabel" VerticalAlignment="Top" HorizontalExpand="True"/>
                        </PanelContainer>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</photo:PhotoCardWindow>
